# Plaid credentials
PLAID_CLIENT_ID=
PLAID_SECRET=
# Use `sandbox` for development unless you explicitly need another Plaid env.
PLAID_ENV=sandbox
PLAID_ACCESS_TOKEN=

# Local application paths
# SQLite database file path (example: ~/.local/share/claw-plaid-ledger/ledger.db)
CLAW_PLAID_LEDGER_DB_PATH=
# OpenClaw workspace path only if you are generating exports there.
CLAW_PLAID_LEDGER_WORKSPACE_PATH=
# Plaid item identifier used as the sync-state key. Single string value.
# Defaults to "default-item". For multi-institution households, run the sync
# command once per institution with a distinct value here (e.g. via separate
# .env files or shell scripts). Each value gets its own cursor in the DB.
# Example: CLAW_PLAID_LEDGER_ITEM_ID=chase-checking
CLAW_PLAID_LEDGER_ITEM_ID=

# HTTP server settings (used by `ledger serve`)
# Host to bind to. Defaults to 127.0.0.1 (local-only). Never set to 0.0.0.0
# unless you are intentionally exposing the server to the network.
CLAW_SERVER_HOST=127.0.0.1
# TCP port to listen on. Defaults to 8000.
CLAW_SERVER_PORT=8000
# Bearer token required on all non-health HTTP endpoints. Must be set before
# starting the server. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CLAW_API_SECRET=
# Shared secret for verifying Plaid webhook HMAC-SHA256 signatures.
# Set to the value from your Plaid dashboard under Webhooks > Signing secret.
# If unset, all incoming webhook signature checks fail closed (rejected).
PLAID_WEBHOOK_SECRET=
