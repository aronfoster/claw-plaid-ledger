# Plaid credentials
# PRODUCTION SENSITIVE: Use separate values for sandbox and production.
# Production keys are different from sandbox keys — never mix environments.
PLAID_CLIENT_ID=
# PRODUCTION SENSITIVE: Never commit this value or store it in plaintext
# outside ~/.config/claw-plaid-ledger/.env (mode 600).
PLAID_SECRET=
# Environment selector. Use `sandbox` for development; set to `production`
# before running any live sync. Running `ledger doctor --production-preflight`
# will warn if this is still set to `sandbox`.
# ENVIRONMENT SEPARATION: sandbox and production must use different DB files
# and different credential sets. See RUNBOOK.md §5 for isolation guidance.
PLAID_ENV=sandbox
# PRODUCTION SENSITIVE: Plaid access token from a completed Link flow.
# Used in single-item mode (`ledger sync` with no flags). For multi-institution
# households, leave this unset and use items.toml with `ledger sync --all`.
# Never commit this value. Treat it like a password.
PLAID_ACCESS_TOKEN=

# Local application paths
# SQLite database file path (example: ~/.local/share/claw-plaid-ledger/ledger.db)
# ENVIRONMENT SEPARATION: use a distinct path per environment
# (e.g. ledger-sandbox.db vs ledger.db) to prevent data mixing.
CLAW_PLAID_LEDGER_DB_PATH=
# OpenClaw workspace path only if you are generating exports there.
CLAW_PLAID_LEDGER_WORKSPACE_PATH=
# Plaid item identifier for single-item mode. Used by `ledger sync` (no flags).
# Defaults to "default-item". For multi-institution households, create
# ~/.config/claw-plaid-ledger/items.toml and use `ledger sync --all`.
CLAW_PLAID_LEDGER_ITEM_ID=

# HTTP server settings (used by `ledger serve`)
# Host to bind to. Defaults to 127.0.0.1 (local-only). Never set to 0.0.0.0
# unless you are intentionally exposing the server to the network.
CLAW_SERVER_HOST=127.0.0.1
# TCP port to listen on. Defaults to 8000.
CLAW_SERVER_PORT=8000
# PRODUCTION SENSITIVE: Bearer token required on all non-health HTTP endpoints.
# Must be set before starting the server. This is a required preflight check.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CLAW_API_SECRET=
# PRODUCTION SENSITIVE: Shared secret for verifying Plaid webhook
# HMAC-SHA256 signatures. Set to the value from your Plaid dashboard under
# Webhooks > Signing secret. If unset, all webhook signature checks fail
# closed (rejected). Required for webhook-triggered sync in production.
PLAID_WEBHOOK_SECRET=
# Log level for the HTTP server. Defaults to INFO. Valid values: DEBUG, INFO,
# WARNING, ERROR, CRITICAL. Uses Python standard logging level names.
# Format: %(asctime)s %(levelname)s %(name)s: %(message)s (journald-friendly)
CLAW_LOG_LEVEL=INFO

# OpenClaw notification (optional)
# After a sync that adds, modifies, or removes transactions, a POST is sent to
# OpenClaw's /hooks/agent endpoint to wake Hestia as ingestion worker.
# Athena runs later on schedule/anomaly flags. Set OPENCLAW_HOOKS_TOKEN
# to enable; leave unset to disable silently.
OPENCLAW_HOOKS_URL=http://127.0.0.1:18789/hooks/agent
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_HOOKS_AGENT=Hestia
OPENCLAW_HOOKS_WAKE_MODE=now
