# Plaid credentials
PLAID_CLIENT_ID=
PLAID_SECRET=
# Use `sandbox` for development unless you explicitly need another Plaid env.
PLAID_ENV=sandbox
PLAID_ACCESS_TOKEN=

# Local application paths
# SQLite database file path (example: ~/.local/share/claw-plaid-ledger/ledger.db)
CLAW_PLAID_LEDGER_DB_PATH=
# OpenClaw workspace path only if you are generating exports there.
CLAW_PLAID_LEDGER_WORKSPACE_PATH=
